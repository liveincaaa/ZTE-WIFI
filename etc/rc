	value=$(cat /etc_rw/sim_esim)
	if [[ "$value" == "0" ]]; then
	echo 0 > /sys/tw_info/sim_esim
	elif [[ "$value" == "1" ]]; then
	echo 1 > /sys/tw_info/sim_esim
	elif [[  "$value" == "2" ]]; then
	echo 2 > /sys/tw_info/sim_esim
	fi
